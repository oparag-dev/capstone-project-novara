# Terraform
**/.terraform/*
*.tfstate
*.tfstate.*
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraform.lock.hcl

# Terraform variables and plans
*.tfvars
*.tfplan
terraform.tfvars
terraform.tfvars.json

# AWS and secrets
.env
.env.*
*.pem
*.key
*.crt
*.p12
credentials
secrets.yaml
secrets.yml

# Kubernetes
kubeconfig
*.kubeconfig

# Ansible
*.retry

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/

# Node
node_modules/
dist/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Docker
*.tar

# IDE and OS files
.vscode/
.idea/
.DS_Store
Thumbs.db


cat > .gitignore <<'EOF'
